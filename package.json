{
  "name": "@moss/openclaw-openwebui-moss",
  "version": "0.1.0",
  "description": "Production-ready OpenClaw plugin and bridge for secure Open WebUI channel integration with Moss agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "openclaw-openwebui-moss": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "openclaw",
    "open-webui",
    "moss",
    "plugin",
    "socketio"
  ],
  "author": "Moss",
  "license": "MIT",
  "dependencies": {
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
