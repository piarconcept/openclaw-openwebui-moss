{
  "name": "@moss/openclaw-openwebui-moss",
  "version": "0.1.0",
  "description": "OpenAI-compatible model provider that exposes filesystem-backed Moss models for Open WebUI via OpenClaw.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "openclaw-openwebui-moss": "dist/provider-standalone.js",
    "openclaw-openwebui-moss-provider": "dist/provider-standalone.js",
    "openclaw-openwebui-moss-bridge": "dist/standalone.js"
  },
  "scripts": {
    "dev": "tsx watch src/provider-standalone.ts",
    "dev:bridge": "tsx watch src/standalone.ts",
    "dev:provider": "tsx watch src/provider-standalone.ts",
    "start": "node dist/provider-standalone.js",
    "start:bridge": "node dist/standalone.js",
    "start:provider": "node dist/provider-standalone.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "npm run build"
  },
  "keywords": [
    "openclaw",
    "open-webui",
    "moss",
    "provider",
    "openai-compatible",
    "filesystem-models",
    "agent-routing",
    "plugin"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "author": "Moss",
  "license": "MIT",
  "dependencies": {
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
